# Ex-Employee Verification Portal - Environment Variables
# Copy this file to .env.local and fill in the values

# ============================================
# REQUIRED - Oracle Database
# ============================================
# Format: (DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=...)(PORT=...))(CONNECT_DATA=(SERVICE_NAME=...)))
ORACLE_USER=your_oracle_username
ORACLE_PASSWORD=your_oracle_password
ORACLE_CONNECTION_STRING=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=your_host)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=your_service_name)))

# ============================================
# REQUIRED - Authentication
# ============================================
JWT_SECRET=your-super-secure-jwt-secret-key-at-least-32-chars

# ============================================
# OPTIONAL - Email Service (currently disabled)
# ============================================
# Email provider: sendgrid, resend, ab_test, fallback
# EMAIL_PROVIDER=sendgrid

# SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Resend (alternative)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email sender configuration
# FROM_EMAIL=noreply@yourdomain.com
# SUPPORT_EMAIL=hr@yourdomain.com
# COMPANY_NAME=Your Company Name

# ============================================
# OPTIONAL - File Storage (Vercel Blob) - Currently Disabled
# ============================================
# BLOB_READ_WRITE_TOKEN=vercel_blob_xxxxxxxxxxxxxxxxxxxx

# ============================================
# OPTIONAL - Application Config
# ============================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

# ============================================
# DEVELOPMENT OPTIONS
# ============================================
ENABLE_TEST_MODE=true
